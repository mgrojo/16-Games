with "../ASFML/asfml.gpr";
with "Ada_Box2d/library/box2d.gpr";

project Volleyball is

   for Create_Missing_Dirs use "True";

   for Source_Dirs use (".");
   for Object_Dir use "obj";
   for Exec_Dir use ".";
   for Main use ("volleyball.adb");

   package Compiler is
      for Default_Switches ("Ada") use
        ("-g",
         "-gnatwa",
         "-gnatVa");
   end Compiler;

end Volleyball;
