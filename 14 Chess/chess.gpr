with "../../ASFML/asfml.gpr";

project Chess is

   for Create_Missing_Dirs use "True";

   for Source_Dirs use (".");
   for Object_Dir use "obj";
   for Main use ("chess.adb");
   for Exec_Dir use ".";

   package Compiler is
      for Default_Switches ("Ada") use
        ("-g",
         "-gnatwa",
         "-gnatVa");
   end Compiler;

end Chess;
