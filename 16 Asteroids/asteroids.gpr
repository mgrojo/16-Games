with "../../ASFML/asfml.gpr";

project Asteroids is

   for Create_Missing_Dirs use "True";

   for Source_Dirs use (".");
   for Object_Dir use "obj";
   for Main use ("asteroids.adb");
   for Exec_Dir use ".";

   package Compiler is
      for Default_Switches ("Ada") use
        ("-g",
         "-gnatwa",
         "-gnatVa");
   end Compiler;

end Asteroids;
