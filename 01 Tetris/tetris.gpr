with "../../ASFML/asfml.gpr";

project Tetris is

   for Create_Missing_Dirs use "True";

   for Source_Dirs use (".");
   for Object_Dir use "obj";
   for Main use ("tetris.adb");
   for Exec_Dir use ".";

   package Compiler is
      for Default_Switches ("Ada") use
        ("-g",
         "-gnatwa",  -- All warnings
         "-gnatVa");  -- All validity checks
   end Compiler;

end Tetris;
